# ESDC API Credentials
ESDC_USER="SET_USERNAME_HERE"
ESDC_PASS="SET_PASSWORD_HERE"

# ESDC API URL
ESDC_URL="https://esdc.skkmigas.go.id/"

# SSL Certificate Verification
# Set to "false" to skip verification (suppresses InsecureRequestWarning)
# Default: true (verify SSL certificates)
#ESDC_VERIFY_SSL="true"

# Logging Level (overrides config.yaml)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL, 0 (disable)
# Useful for debugging: ESDC_LOG_LEVEL=DEBUG
#ESDC_LOG_LEVEL="INFO"

# Arize Phoenix Observability
# Enable Phoenix tracing for LLM observability
#PHOENIX_ENABLED="true"
# Phoenix collector endpoint (default: http://localhost:4317)
#PHOENIX_COLLECTOR_ENDPOINT="http://localhost:4317"
# Phoenix project name (default: iris)
#PHOENIX_PROJECT_NAME="iris"
